# Environment Configuration Example
# Copy this file to .env and update values for your deployment

# Application Environment
ENVIRONMENT=development
DEBUG=true

# Backend Configuration
BACKEND_PORT=8000
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql://halo_user:halo_password@database:5432/halo_watch
# For SQLite (development): DATABASE_URL=sqlite:///./data/halo_watch.db

# PostgreSQL Database
POSTGRES_DB=halo_watch
POSTGRES_USER=halo_user
POSTGRES_PASSWORD=halo_password

# Redis Configuration
REDIS_PASSWORD=redis_password
REDIS_URL=redis://:redis_password@redis:6379/0

# Frontend Configuration
FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:80

# Nginx Configuration
HTTP_PORT=80
HTTPS_PORT=443

# Monitoring Configuration (optional)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin

# SSL Configuration
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM

# Alert Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_FROM=noreply@halowatch.com
ALERT_EMAIL_TO=admin@hospital.com

# Device Configuration
DEVICE_HEARTBEAT_TIMEOUT=300  # 5 minutes
WRISTBAND_BATTERY_LOW_THRESHOLD=20
RECEIVER_OFFLINE_THRESHOLD=600  # 10 minutes

# Security Configuration
RATE_LIMIT_PER_MINUTE=60
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=900  # 15 minutes

# Data Retention
DATA_RETENTION_DAYS=90
LOG_RETENTION_DAYS=30