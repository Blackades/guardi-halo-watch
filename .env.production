# Production Environment Configuration
ENVIRONMENT=production
DEBUG=false

# Backend Configuration
BACKEND_PORT=8000
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
LOG_LEVEL=INFO

# Database Configuration (PostgreSQL for production)
DATABASE_URL=postgresql://halo_user:CHANGE_THIS_PASSWORD@database:5432/halo_watch

# PostgreSQL Database
POSTGRES_DB=halo_watch
POSTGRES_USER=halo_user
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD

# Redis Configuration
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379/0

# Frontend Configuration
FRONTEND_PORT=3000
REACT_APP_API_URL=https://your-domain.com
REACT_APP_WS_URL=wss://your-domain.com

# CORS Configuration
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Nginx Configuration
HTTP_PORT=80
HTTPS_PORT=443

# Monitoring Configuration
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD

# SSL Configuration
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Backup Configuration
BACKUP_RETENTION_DAYS=90
BACKUP_SCHEDULE=0 2 * * *

# Alert Configuration
SMTP_SERVER=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=alerts@your-domain.com
SMTP_PASSWORD=CHANGE_THIS_SMTP_PASSWORD
ALERT_EMAIL_FROM=noreply@your-domain.com
ALERT_EMAIL_TO=admin@your-hospital.com

# Device Configuration
DEVICE_HEARTBEAT_TIMEOUT=300
WRISTBAND_BATTERY_LOW_THRESHOLD=20
RECEIVER_OFFLINE_THRESHOLD=600

# Security Configuration (strict for production)
RATE_LIMIT_PER_MINUTE=60
MAX_LOGIN_ATTEMPTS=3
ACCOUNT_LOCKOUT_DURATION=1800

# Data Retention
DATA_RETENTION_DAYS=90
LOG_RETENTION_DAYS=30